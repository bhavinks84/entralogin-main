# EntraLogin backend environment template
# Copy this file to backend/.env and fill values.

# Server
PORT=5000
NODE_ENV=production

# Single-server deployment mode (no nginx required)
# true  -> backend serves frontend/dist and SPA routes
# false -> use separate frontend server (for local dev)
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=../frontend/dist

# Database and cache
MONGODB_URI=mongodb://127.0.0.1:27017/entralogin
REDIS_URL=redis://127.0.0.1:6379

# JWT secrets (generate with: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_HEX_CHARS

# Public frontend URL (used by CORS and invitation redirect URL)
FRONTEND_URL=http://localhost:5000

# Microsoft Entra External ID (invitation flow)
ENTRA_CLIENT_ID=your-application-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_ID=your-directory-tenant-id
ENTRA_TENANT_SUBDOMAIN=your-tenant-subdomain
ENTRA_TENANT_DOMAIN=your-tenant-subdomain.onmicrosoft.com
ENTRA_REDIRECT_URI=http://localhost:5000/api/auth/entra/callback

# Optional SMTP (only required if using OTP/password-reset endpoints)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=EntraLogin
EMAIL_FROM_ADDRESS=noreply@example.com
