# ─────────────────────────────────────────────────
#  EntraLogin – backend environment template
#  Copy to .env and fill in every value.
#  deploy.sh writes .env automatically.
# ─────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/entralogin
# Auth:   mongodb://user:pass@127.0.0.1:27017/entralogin?authSource=entralogin
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/entralogin
MONGODB_URI=mongodb://127.0.0.1:27017/entralogin

# ── Cache / session store ─────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT secrets ───────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64_HEX_CHARS

# ── Frontend ──────────────────────────────────────
# Must match the public URL served by Nginx
FRONTEND_URL=https://your-domain.com

# ── Microsoft Entra External ID ───────────────────
# See ENTRA_SETUP.md and DEPLOYMENT.md §3 for how to obtain these.
ENTRA_CLIENT_ID=your-application-client-id
ENTRA_CLIENT_SECRET=your-client-secret
ENTRA_TENANT_ID=your-directory-tenant-id
ENTRA_TENANT_SUBDOMAIN=your-tenant-subdomain
ENTRA_REDIRECT_URI=https://your-domain.com/api/auth/entra/callback

# ── SMTP / Email ──────────────────────────────────
# Required: OTP verification emails will not be sent without a working SMTP server.
# Recommended providers: SendGrid, Postmark, AWS SES, Mailgun
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-smtp-api-key-or-password
EMAIL_FROM_NAME=EntraLogin
EMAIL_FROM_ADDRESS=noreply@your-domain.com
